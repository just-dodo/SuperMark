{
  "name": "@justdodo/supermark",
  "version": "0.1.3",
  "description": "AI-powered file digestion system — auto-generates markdown documentation for every file",
  "type": "module",
  "bin": {
    "supermark": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "scripts",
    "supermark.config.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/just-dodo/SuperMark.git"
  },
  "homepage": "https://github.com/just-dodo/SuperMark",
  "bugs": {
    "url": "https://github.com/just-dodo/SuperMark/issues"
  },
  "keywords": [
    "markdown",
    "ai",
    "documentation",
    "file-watcher",
    "digest",
    "llm",
    "openai",
    "gemini",
    "transcription",
    "pdf",
    "video"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "csv-parse": "^6.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "js-yaml": "^4.1.1",
    "linkedom": "^0.18.12",
    "mammoth": "^1.11.0",
    "openai": "^6.27.0",
    "p-queue": "^9.1.0",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
